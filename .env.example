# BSC Testnet Deployment Environment Variables

# Your wallet private key (without 0x prefix)
# Get this from MetaMask: Account Details > Export Private Key
# ⚠️  NEVER commit this to version control!
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Optional: BSCScan API Key for verification
# Get from: https://bscscan.com/apis
BSCSCAN_API_KEY=your_bscscan_api_key_here